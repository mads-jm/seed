filters:
  and:
    - file.inFolder("01 concepts")
views:
  - type: table
    name: All Concepts
    order:
      - file.name
  - type: table
    name: By Tag
    filters:
      and:
        - note.tags:*
    groupBy:
      property: tags
      direction: ASC
    order:
      - file.name
  - type: table
    name: Recently Modified
    order:
      - date modified
